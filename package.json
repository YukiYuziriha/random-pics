{
  "type": "module",
  "devDependencies": {
    "@types/bun": "^1.3.6",
    "@types/react": "^19.2.8",
    "@types/react-dom": "^19.2.3",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/plugin-dialog": "^2.6.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3"
  },
  "scripts": {
    "build": "bun build ./src/main.tsx --outdir ./dist --minify",
    "build:tauri": "rm -rf ./dist-tauri && mkdir -p ./dist-tauri && bun build ./src/main.tsx --outdir ./dist-tauri/dist --minify && cp ./index.html ./dist-tauri/index.html",
    "build:watch": "bun build ./src/main.tsx --outdir ./dist --minify --watch",
    "build:watch:tauri": "rm -rf ./dist-tauri && mkdir -p ./dist-tauri && cp ./index.html ./dist-tauri/index.html && bun build ./src/main.tsx --outdir ./dist-tauri/dist --minify --watch",
    "dev": "bun run build:watch",
    "test": "bun run test:rust",
    "test:list": "cargo test --manifest-path src-tauri/Cargo.toml --lib -- --list",
    "test:domain": "bun run test:rust",
    "test:api": "bun run test:rust",
    "test:rust": "cargo test --manifest-path src-tauri/Cargo.toml --lib",
    "test:tsc": "bun tsc",
    "test:ci": "bun run test:rust && bun run test:tsc"
  }
}
